{
  "name": "invitation-service",
  "version": "3.0.0",
  "description": "Omnixys Invitation Service",
  "author": {
    "name": "Caleb Gyamfi",
    "email": "caleb@omnixys.com",
    "url": "https://omnixys.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/omnixys/invitation-service.git"
  },
  "bugs": {
    "url": "https://github.com/omnixys/invitation-service/issues"
  },
  "homepage": "https://omnixys.com",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.10.0",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo",
    "build": "pnpm run clean && nest build",
    "format": "prettier --cache --write \"src/**/*.{ts,js,json,prisma,md,yaml}\"",
    "format:test": "prettier --cache --write \"src/**/*.{ts,js,json,prisma,md,yaml}\" \"__tests__/**/*.ts\"",
    "format:check": "prettier --cache --check \"src/**/*.{ts,js,json,prisma,md,yaml,yml}\" \"__test__/**/*.ts\"",
    "start": "pnpm nest start",
    "dev": "pnpm run clean && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config ./jest-e2e.json --maxWorkers=4 --coverage",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e:debug": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand --detectOpenHandles --config ./jest-e2e.json",
    "test:e2e2": "jest --config ./jest-e2e.json",
    "test:e2e": "NODE_OPTIONS='--experimental-vm-modules' jest --config ./jest-e2e.json",
    "test:unit": "pnpm run build && node --test __tests__/unit/*.test.mjs",
    "typedoc": "typedoc",
    "depcheck": "depcheck",
    "test:invitation": "pnpm test -- __tests__/e2e/invitation/invitation-resolvers.e2e-spec.ts",
    "prepare": "husky",
    "prisma:migrate": "prisma migrate dev",
    "reset": "prisma migrate reset --force && prisma migrate dev && tsx prisma/seed.ts",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:validate": "tsx prisma/validate.ts",
    "prisma:push": "prisma db push",
    "prisma:pull": "prisma db pull",
    "generate": "pnpm prisma format && pnpm prisma validate && prisma generate",
    "release": "semantic-release",
    "deps:audit": "tsx scripts/dependency-audit.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@apollo/subgraph": "^2.14.3",
    "@as-integrations/fastify": "^3.1.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.1.2",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@nestjs/apollo": "^13.4.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/graphql": "^13.4.2",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/terminus": "^11.1.1",
    "@omnixys/cache": "^3.0.1",
    "@omnixys/context": "^3.0.0",
    "@omnixys/contracts": "^3.1.0",
    "@omnixys/graphql": "^3.0.1",
    "@omnixys/kafka": "^3.1.1",
    "@omnixys/logger": "^3.1.0",
    "@omnixys/media": "^3.0.0",
    "@omnixys/observability": "^3.1.0",
    "@omnixys/security": "^3.0.2",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "cfonts": "^3.3.1",
    "chalk": "^5.6.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dataloader": "^2.2.3",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "fastify": "5.8.5",
    "papaparse": "^5.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "latest",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "latest",
    "@nestjs/testing": "^11.1.28",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@tsconfig/node23": "^23.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.20.1",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "depcheck": "latest",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.6",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sort-imports": "^1.8.11",
    "prisma": "^7.9.0",
    "semantic-release": "^25.0.8",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.12",
    "ts-morph": "^27.0.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0"
  },
  "pnpm": {
    "overrides": {
      "fastify": "5.8.5"
    }
  }
}
