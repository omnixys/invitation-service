generator client {
  provider = "prisma-client"
  output   = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
  schemas  = ["invitation"]
}

model Invitation {
  id String @id @default(cuid()) @map("id")

  firstName String @map("first_name")
  lastName  String @map("last_name")

  eventId        String  @map("event_id")
  guestProfileId String? @map("guest_profile_id")
  email          String? @map("email")

  status InvitationStatus @default(PENDING) @map("status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  pendingContactId String? @unique @map("pending_contact_id")

  rsvpChoice RsvpChoice? @map("rsvp_choice")
  rsvpAt     DateTime?   @map("rsvp_at")

  approvedAt       DateTime? @map("approved_at")
  approvedByUserId String?   @map("approved_by_user_id")

  maxInvitees Int @default(0) @map("max_invitees")

  invitedByInvitationId String?     @map("invited_by_invitation_id")
  invitedByInvitation   Invitation? @relation("invitation_by_invitation", fields: [invitedByInvitationId], references: [id], onDelete: Cascade)
  invitedByUserId       String?     @map("invited_by_user_id")

  preferredLanguage Language? @map("preferred_language") @default(ENGLISH)
  preferredContactType ContactType? @map("preferred_contact_type") @default(EMAIL)

  plusOnes     Invitation[]  @relation("invitation_by_invitation")
  phoneNumbers PhoneNumber[]

  @@index([eventId, status])
  @@index([eventId, rsvpChoice])
  @@index([invitedByInvitationId])
  @@index([eventId])
  @@map("invitation")
  @@schema("invitation")
}

model PhoneNumber {
  id           String @id @default(cuid()) @map("id")
  invitationId String @map("invitation_id")

  number      String          @map("number")
  type        PhoneNumberType @map("type")
  label       String?         @map("label")
  isPrimary   Boolean         @default(false) @map("is_primary")
  countryCode String          @map("country_code")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([countryCode, number])
  @@index([invitationId])
  @@index([invitationId, isPrimary])
  @@map("phone_number")
  @@schema("invitation")
}

enum ContactType {
  EMAIL
  PHONE

  @@schema("invitation")
}

enum Language {
  ENGLISH
  SPANISH
  FRENCH
  GERMAN
  CHINESE
  JAPANESE
  OTHER

  @@schema("invitation")
}

enum PhoneNumberType {
  WHATSAPP
  MOBILE
  PRIVATE
  WORK
  HOME
  OTHER

  @@schema("invitation")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
  REJECTED
  APPROVED

  @@schema("invitation")
}

enum RsvpChoice {
  YES
  NO
  MAYBE

  @@schema("invitation")
}
