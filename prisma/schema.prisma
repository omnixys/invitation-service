generator client {
  provider = "prisma-client"
  output   = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model Invitation {
  id   String         @id @default(uuid()) @map("id") @db.Uuid
  type InvitationType

  firstName String @map("first_name")
  lastName  String @map("last_name")

  eventId             String              @map("event_id") @db.Uuid
  eventName           String?             @map("event_name")
  eventEndsAt         DateTime?           @map("event_ends_at")
  autoApproveOnAccept Boolean             @default(false) @map("auto_approve_on_accept")
  guestProfileId      String?             @map("guest_profile_id") @db.Uuid
  email               String?             @map("email")
  phoneNumber         String?             @map("phone_number")
  selectedInvitedBy   String[]            @default([]) @map("selected_invited_by")
  guestNote           String?             @map("guest_note")
  plusOneAgeCategory  PlusOneAgeCategory? @map("plus_one_age_category")

  status InvitationStatus @default(PENDING) @map("status")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  pendingContactId String? @unique @map("pending_contact_id")

  rsvpChoice RsvpChoice? @map("rsvp_choice")
  rsvpAt     DateTime?   @map("rsvp_at")

  approvedAt       DateTime? @map("approved_at")
  approvedByUserId String?   @map("approved_by_user_id")

  maxInvitees Int @default(0) @map("max_invitees")

  invitedByInvitationId String?     @map("invited_by_invitation_id") @db.Uuid
  invitedByInvitation   Invitation? @relation("invitation_by_invitation", fields: [invitedByInvitationId], references: [id], onDelete: Cascade)
  invitedByUserId       String?     @map("invited_by_user_id") @db.Uuid

  plusOnes     Invitation[]  @relation("invitation_by_invitation")
  phoneNumbers PhoneNumber[]

  @@index([eventId, status])
  @@index([eventId, rsvpChoice])
  @@index([invitedByInvitationId])
  @@index([eventId])
  @@map("invitation")
}

model PhoneNumber {
  id           String @id @default(uuid()) @map("id") @db.Uuid
  invitationId String @map("invitation_id") @db.Uuid

  number      String          @map("number")
  type        PhoneNumberType @map("type")
  label       String?         @map("label")
  isPrimary   Boolean         @default(false) @map("is_primary")
  countryCode String          @map("country_code")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([countryCode, number])
  @@index([invitationId])
  @@index([invitationId, isPrimary])
  @@map("phone_number")
}

model EventRoleProjection {
  id        String        @id @default(uuid()) @map("id") @db.Uuid
  eventId   String        @map("event_id") @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  role      EventRoleType @map("role")
  updatedAt DateTime?     @updatedAt @map("updated_at")

  @@unique([eventId, userId], name: "uq_event_role_projection")
  @@index([eventId], name: "idx_event_role_projection_event")
  @@map("event_role_projection")
}

model EventAccessProjection {
  id          String    @id @default(uuid()) @map("id") @db.Uuid
  eventId     String    @map("event_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  permissions String[]  @default([]) @map("permissions")
  roles       Json?     @map("roles")
  occurredAt  DateTime? @map("occurred_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  @@unique([eventId, userId], name: "uq_event_access_projection")
  @@index([eventId], name: "idx_event_access_projection_event")
  @@map("event_access_projection")
}

/// ----------------------------------------------------------------------
/// EventSettingsProjection – local cache of event settings synced via Kafka
/// Fields are scoped to what the Invitation Service actually needs.
/// ----------------------------------------------------------------------
model EventSettingsProjection {
  id                         String    @id @default(uuid()) @map("id") @db.Uuid
  eventId                    String    @unique @map("event_id") @db.Uuid
  name                       String?   @map("name")
  endsAt                     DateTime? @map("ends_at")
  approvalMode               String?   @map("approval_mode")
  allowPublicRsvp            Boolean   @default(false) @map("allow_public_rsvp")
  requireApprovalForPlusOnes Boolean   @default(true) @map("require_approval_for_plus_ones")
  rsvpDeadline               DateTime? @map("rsvp_deadline")
  maxSeats                   Int?      @map("max_seats")
  scheduleTicketRelease      Boolean   @default(false) @map("schedule_ticket_release")
  ticketReleaseAt            DateTime? @map("ticket_release_at")
  updatedAt                  DateTime? @updatedAt @map("updated_at")

  @@map("event_settings_projection")
}

enum EventRoleType {
  ADMIN
  SECURITY
  GUEST
  SUPPORT

  @@map("event_role_type")
}

enum InvitationType {
  PUBLIC
  PRIVATE

  @@map("invitation_type")
}

enum ContactType {
  EMAIL
  PHONE

  @@map("contact_type")
}

enum PhoneNumberType {
  WHATSAPP
  MOBILE
  PRIVATE
  WORK
  HOME
  OTHER

  @@map("phone_number_type")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
  REJECTED
  APPROVED

  @@map("invitation_status")
}

enum RsvpChoice {
  YES
  NO
  MAYBE

  @@map("rsvp_choice")
}

enum PlusOneAgeCategory {
  OVER_SIX
  UNDER_SIX

  @@map("plus_one_age_category")
}
