# @license GPL-3.0-or-later

# Runtime
NODE_ENV=development
SERVICE=invitation-service
PORT=4000
SCHEMA_TARGET=true
COOKIE_SECRET=replace-with-at-least-32-random-characters

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invitation

# Kafka
KAFKA_BROKER=localhost:9092

# Valkey
VALKEY_URL=valkey://localhost:6380
VALKEY_PASSWORD=
PC_TTL_SEC=2592000

# S3-compatible object storage
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY_ID=minio
STORAGE_SECRET_ACCESS_KEY=replace-me
STORAGE_BUCKET=invitation-imports
STORAGE_PUBLIC_URL=
STORAGE_FORCE_PATH_STYLE=true

# Security/JWT verification
KC_URL=http://localhost:18080/auth
KC_REALM=camunda-platform
KC_CLIENT_ID=camunda-identity
KC_CLIENT_SECRET=

# Observability
TEMPO_URI=http://localhost:4318/v1/traces
LOG_LEVEL=debug
LOG_PRETTY=true

# Optional external readiness checks; leave empty to disable
KEYCLOAK_HEALTH_URL=
TEMPO_HEALTH_URL=
PROMETHEUS_HEALTH_URL=
